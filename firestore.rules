// Tandor — Firestore security rules
//
// DEPLOY: `firebase deploy --only firestore:rules`
// NOTE:   No firebase.json is configured in this repo yet. Before the
//         command above can run, a firebase.json with a
//         `"firestore": { "rules": "firestore.rules" }` block must be
//         created (NOT created here on purpose — flag for the maintainer).
//
// Model: every user owns the document tree under users/{uid}/**,
//        including the watchlist subcollection. Everything else is denied.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A user may read/write ONLY their own profile and anything nested
    // beneath it (e.g. users/{uid}/watchlist/{productId}).
    //
    // SÉCURITÉ MONÉTISATION : les champs de plan/abonnement sont VERROUILLÉS côté
    // client. Seul le SDK Admin (webhook Stripe) peut les écrire — et il IGNORE
    // ces rules, donc le webhook continue de fonctionner. Sans ce verrou, un user
    // pouvait écrire {plan:'pro', subscription_active:true} et se débloquer gratis.
    match /users/{uid} {
      function locked() { return ['plan', 'subscription_active', 'stripe_customer_id']; }

      allow read: if request.auth != null && request.auth.uid == uid;

      // Création : autorisée seulement si le doc ne pose aucun champ verrouillé,
      // ou s'il pose les valeurs gratuites par défaut.
      allow create: if request.auth != null && request.auth.uid == uid
                    && (!request.resource.data.keys().hasAny(locked())
                        || (request.resource.data.get('plan', 'free') == 'free'
                            && request.resource.data.get('subscription_active', false) == false));

      // Mise à jour : refusée si elle touche un champ verrouillé.
      allow update: if request.auth != null && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data)
                          .affectedKeys().hasAny(locked());

      allow delete: if false;

      // Sous-collections (watchlist, alertes…) : pleinement contrôlées par le user.
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
