// Tandor — Firestore security rules
//
// DEPLOY: `firebase deploy --only firestore:rules`
// NOTE:   No firebase.json is configured in this repo yet. Before the
//         command above can run, a firebase.json with a
//         `"firestore": { "rules": "firestore.rules" }` block must be
//         created (NOT created here on purpose — flag for the maintainer).
//
// Model: every user owns the document tree under users/{uid}/**,
//        including the watchlist subcollection. Everything else is denied.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A user may read/write ONLY their own profile and anything nested
    // beneath it (e.g. users/{uid}/watchlist/{productId}).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
