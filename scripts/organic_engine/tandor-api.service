[Unit]
Description=Tandor Organic Engine API
After=network-online.target
Wants=network-online.target

[Service]
User=albator
WorkingDirectory=/home/albator/scrappingstuff/scripts/organic_engine
EnvironmentFile=/home/albator/tandor.env
Environment=TANDOR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ExecStart=/home/albator/scrappingstuff/scripts/organic_engine/.venv/bin/uvicorn api.server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
